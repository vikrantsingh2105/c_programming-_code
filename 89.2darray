// program for writing table given bt user using 2 dimensional array
#include<stdio.h>

int main(){
    int n1,n2,n3;
    scanf("5)
    int a[3][10];
    int mul[]={2,3,7};

    for(int i=0; i<3; i++)
    {
        for(int j=0; j<10;j++)
        {
            a[i][j]= mul[i]*(j+1);
        }
    }

    for(int i=0; i<3; i++)
    {
        for(int j=0; j<10;j++)
        {
            printf("%d x %d = %d\n",mul[i],(j+1),a[i][j]);
        }
        printf("\n");        
    }
    return 0;
}